# Production Environment Variables Example
# Copy this file to .env and fill in the values before deploying

# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate_a_strong_password_here
POSTGRES_DB=grekam_os

# Authentication & Security
# Generate a strong random string (e.g. using `openssl rand -base64 32`)
JWT_SECRET=your_production_jwt_secret_here
AUTH_SECRET=your_production_auth_secret_here

# Frontend/API URLs (Update with your VPS IP or Domain)
# Example: http://198.51.100.23:4000/api/v1 or https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:4000/api/v1

# Example: http://198.51.100.23:3000/api/auth or https://yourdomain.com/api/auth
AUTH_URL=http://YOUR_VPS_IP:3000/api/auth
