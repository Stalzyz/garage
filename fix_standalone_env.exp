#!/usr/bin/expect -f
set timeout 30
spawn ssh -o StrictHostKeyChecking=no -o PubkeyAuthentication=no root@72.61.231.187
expect "assword:"
send "Photoshop09@\r"
expect "# "
# Add PORT and HOSTNAME to the standalone .env so child processes pick it up
send "echo '' >> /root/grekam-os/apps/academy-web/.next/standalone/apps/academy-web/.env\r"
expect "# "
send "echo 'PORT=3006' >> /root/grekam-os/apps/academy-web/.next/standalone/apps/academy-web/.env\r"
expect "# "
send "echo 'HOSTNAME=0.0.0.0' >> /root/grekam-os/apps/academy-web/.next/standalone/apps/academy-web/.env\r"
expect "# "
send "cat /root/grekam-os/apps/academy-web/.next/standalone/apps/academy-web/.env\r"
expect "# "
send "pm2 restart 19\r"
expect "# "
send "sleep 5 && netstat -tulnp | grep node\r"
expect "# "
send "pm2 logs grecakam-os-academy --lines 5 --nostream\r"
expect "# "
send "exit\r"
expect eof
