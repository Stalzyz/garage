// This is your Prisma schema file for GREKAM OS
// Full 12-module enterprise platform schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// CORE — Users, Roles, Auth
// ─────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  MANAGER
  STAFF
  CLIENT
  STUDENT
  VENDOR
  INTERN
  EDUCATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(PENDING)
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // 2FA
  twoFaEnabled     Boolean @default(false)
  twoFaSecret      String?
  twoFaBackupCodes String? // JSON array of backup codes

  // Relations
  customRoleId  String?
  customRole    Role?          @relation(fields: [customRoleId], references: [id])
  employee      Employee?
  student       Student?
  educator      Educator?
  vendor        Vendor?
  clientProfile ClientProfile?

  sessions      Session[]
  notifications Notification[]
  auditLogs     AuditLog[]          @relation("AuditUser")
  generatedDocs GeneratedDocument[]
  ForumPost     ForumPost[]
  ForumReply    ForumReply[]
  OfficeHour    OfficeHour[]

  // Chat Relations
  chatParticipants ChatParticipant[] @relation("UserChatParticipants")
  chatMessages     ChatMessage[]     @relation("UserChatMessages")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String // CREATE | UPDATE | DELETE | VIEW
  resource   String // Model name
  resourceId String
  changes    Json? // Before/after diff
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation("AuditUser", fields: [userId], references: [id])

  @@index([resource, resourceId])
  @@index([userId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// ORGANIZATION — Departments, Structure
// ─────────────────────────────────────────

enum BusinessUnit {
  AGENCY // Grekam Visuals
  ACADEMY // Grekam Academy
  BOTH
}

model Department {
  id           String       @id @default(cuid())
  name         String
  businessUnit BusinessUnit
  headId       String?
  createdAt    DateTime     @default(now())

  employees   Employee[]
  Team        Team[]
  Designation Designation[]

  @@map("departments")
}

model Team {
  id           String   @id @default(cuid())
  name         String
  departmentId String
  leaderId     String?
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  employees  Employee[]

  @@map("teams")
}

model Designation {
  id           String   @id @default(cuid())
  title        String
  departmentId String?
  level        Int      @default(1)
  createdAt    DateTime @default(now())

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees  Employee[]

  @@map("designations")
}

// ─────────────────────────────────────────
// WHITELABELING & SETTINGS
// ─────────────────────────────────────────

model Organization {
  id   String @id @default(cuid())
  name String @default("My Agency OS")

  // Whitelabel Branding
  logoUrl         String? // URL to Cloudflare R2
  academyLogoUrl  String? // Separate logo for academy/student documents
  faviconUrl      String?
  primaryColor    String  @default("#2563eb") // Default Blue
  secondaryColor  String  @default("#1e40af")
  accentColor     String  @default("#10b981")
  darkModeDefault Boolean @default(true)

  // Contact Info
  supportEmail   String?
  billingAddress String?
  website        String?
  phone          String?

  // API Integrations
  openAiKey      String?
  resendApiKey   String?

  // Bank Details
  bankName      String?
  accountName   String?
  accountNumber String?
  ifscCode      String?
  swiftCode     String?
  bankBranch    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization")
}

model FinanceSettings {
  id                String  @id @default(cuid())
  baseCurrency      String  @default("INR")
  currencySymbol    String  @default("₹")
  taxModel          String  @default("GST") // GST | VAT | NONE
  gstNumber         String?
  vatNumber         String?
  fiscalYearStart   Int     @default(4) // 4 = April (India), 1 = January
  invoicePrefix     String  @default("INV")
  invoiceNextNumber Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("finance_settings")
}

model IntegrationKey {
  id             String   @id @default(cuid())
  service        String // RAZORPAY | PHONEPE | STRIPE | SMTP | WHATSAPP | GOOGLE
  keyName        String // e.g. KEY_ID, SECRET_KEY, WEBHOOK_SECRET
  encryptedValue String // AES-256 encrypted value
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([service, keyName])
  @@map("integration_keys")
}

// ─────────────────────────────────────────
// MODULE 01 — CRM
// ─────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  ENQUIRY
  COUNSELLING
  TRIAL
  ENROLLED_ACADEMY
  DROPPED
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  REFERRAL
  COLD_OUTREACH
  INSTAGRAM
  LINKEDIN
  ACADEMY_ALUMNI
  OTHER
}

enum ClientTier {
  GOLD
  SILVER
  BRONZE
}

model ClientSubscription {
  id               String   @id @default(cuid())
  clientId         String
  domain           String   // e.g., "atlas.grekam.in"
  licenseKey       String   @unique
  status           String   @default("ACTIVE") // ACTIVE, PAST_DUE, SUSPENDED, CANCELLED
  expiryDate       DateTime
  
  // Razorpay Fields
  razorpayPlanId   String?  // The automated monthly plan ID
  razorpaySubId    String?  @unique // The active subscription ID
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  client           ClientProfile @relation(fields: [clientId], references: [id])

  @@map("client_subscriptions")
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  status          LeadStatus @default(NEW)
  source          LeadSource
  score           Int        @default(0)
  estimatedBudget Float?
  projectType     String?
  notes           String?
  assignedToId    String?
  lostReason      String?
  businessUnit    String     @default("AGENCY")
  courseInterest  String?
  batchId         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  activities LeadActivity[]
  proposals  Proposal[]

  @@index([status])
  @@index([assignedToId])
  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String // CALL | EMAIL | WHATSAPP | MEETING | NOTE
  content   String
  userId    String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_activities")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  website   String?
  industry  String?
  size      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts      Contact[]
  projects      Project[]
  subscriptions Subscription[]

  @@map("companies")
}

model Subscription {
  id          String   @id @default(cuid())
  companyId   String
  productName String
  planName    String
  mrr         Float
  status      String   @default("active") // active | paused | at_risk | churned
  nextBilling DateTime
  usage       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Contact {
  id        String      @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  whatsapp  String?
  companyId String?
  tier      ClientTier?
  isPrimary Boolean     @default(false)
  tags      String[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company           Company?           @relation(fields: [companyId], references: [id])
  clientProfile     ClientProfile?
  communicationLogs CommunicationLog[]
  proposals         Proposal[]

  @@map("contacts")
}

model CommunicationLog {
  id        String   @id @default(cuid())
  contactId String
  type      String // CALL | EMAIL | WHATSAPP | MEETING
  direction String // INBOUND | OUTBOUND
  summary   String
  userId    String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id])

  @@map("communication_logs")
}

model ClientProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  contactId String? @unique

  user    User     @relation(fields: [userId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  subscriptions ClientSubscription[]

  @@map("client_profiles")
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
}

model Proposal {
  id            String         @id @default(cuid())
  leadId        String?
  contactId     String?
  title         String
  status        ProposalStatus @default(DRAFT)
  version       Int            @default(1)
  validUntil    DateTime?
  subtotal      Float          @default(0)
  discountRate  Float          @default(0)
  taxRate       Float          @default(0)
  tax           Float          @default(0)
  totalAmount   Float
  currency      String         @default("INR")
  notes         String?
  signedAt      DateTime?
  signatureUrl  String?
  publicToken   String?        @unique
  signatureData String?        @db.Text
  isTemplate    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  lead          Lead?               @relation(fields: [leadId], references: [id])
  contact       Contact?            @relation(fields: [contactId], references: [id])
  items         ProposalItem[]
  generatedDocs GeneratedDocument[]

  @@map("proposals")
}

model ProposalItem {
  id          String @id @default(cuid())
  proposalId  String
  description String
  quantity    Float
  unitPrice   Float
  unit        String // hours | days | units | license
  discountRate Float @default(0)
  taxRate      Float @default(0)
  total       Float
  sortOrder   Int    @default(0)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("proposal_items")
}

// ─────────────────────────────────────────
// MODULE 02 — Project Management
// ─────────────────────────────────────────

enum ProjectStatus {
  BRIEFING
  DISCOVERY
  CONCEPT
  PRODUCTION
  REVIEW
  DELIVERY
  CLOSED
  ON_HOLD
}

enum ProjectType {
  BRAND_IDENTITY
  WEBSITE
  CAMPAIGN
  MOTION
  FULL_PACKAGE
  CUSTOM
}

model Project {
  id          String        @id @default(cuid())
  name        String
  type        ProjectType
  status      ProjectStatus @default(BRIEFING)
  companyId   String?
  managerId   String
  budget      Float?
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company  Company?       @relation(fields: [companyId], references: [id])
  phases   ProjectPhase[]
  tasks    Task[]
  files    ProjectFile[]
  brief    Brief?
  timeLogs TimeLog[]
  estimates Estimate[]
  billingSchedule BillingSchedule?

  @@index([status])
  @@map("projects")
}

model BillingSchedule {
  id        String   @id @default(cuid())
  projectId String   @unique
  type      String   // ONE_TIME | INSTALLMENTS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestones BillingMilestone[]

  @@map("billing_schedules")
}

model BillingMilestone {
  id              String   @id @default(cuid())
  scheduleId      String
  name            String   // e.g., "Advance Payment", "Final Handover"
  amount          Float
  dueDate         DateTime?
  status          String   @default("PENDING") // PENDING, INVOICED, PAID
  invoiceId       String?  @unique // Links to the actual Invoice
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedule  BillingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  invoice   Invoice?        @relation(fields: [invoiceId], references: [id])

  @@map("billing_milestones")
}

model ProjectPhase {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  sortOrder   Int
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  clientNotes String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("project_phases")
}

enum TaskPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

model Task {
  id           String       @id @default(cuid())
  projectId    String
  phaseId      String?
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(NORMAL)
  assigneeId   String?
  estimatedHrs Float?
  dueDate      DateTime?
  completedAt  DateTime?
  parentTaskId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       ProjectPhase?    @relation(fields: [phaseId], references: [id])
  subtasks    Task[]           @relation("TaskSubtasks")
  parentTask  Task?            @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
  comments    TaskComment[]
  attachments TaskAttachment[]
  timeLogs    TimeLog[]

  @@index([projectId, status])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  filename   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_attachments")
}

model ProjectFile {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  folderPath  String    @default("/")
  fileUrl     String
  fileSize    Int
  mimeType    String
  version     Int       @default(1)
  uploadedBy  String
  isDelivery  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  approvedAt  DateTime?
  approvedBy  String?
  clientNotes String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  markers FileMarker[]

  @@map("project_files")
}

model FileMarker {
  id         String   @id @default(cuid())
  fileId     String
  userId     String   // The client or staff who left the marker
  xPercent   Float?   // X coordinate percentage (0-100)
  yPercent   Float?   // Y coordinate percentage (0-100)
  timestamp  Float?   // For videos (seconds)
  comment    String
  resolved   Boolean  @default(false)
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  file       ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@map("file_markers")
}

model Brief {
  id           String   @id @default(cuid())
  projectId    String   @unique
  templateType String
  content      Json // Flexible JSON for different brief types
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("briefs")
}

model TimeLog {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  userId      String
  hours       Float
  description String?
  logDate     DateTime @default(now())
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  task    Task?   @relation(fields: [taskId], references: [id])

  @@map("time_logs")
}

// ─────────────────────────────────────────
// MODULE 03 — Staff & HR
// ─────────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
}

model Employee {
  id               String         @id @default(cuid())
  userId           String         @unique
  employeeCode     String         @unique
  departmentId     String?
  jobTitle         String
  employmentType   EmploymentType @default(FULL_TIME)
  managerId        String?
  joiningDate      DateTime
  salary           Float?
  currency         String         @default("INR")
  skills           String[]
  bio              String?
  bloodGroup       String?
  emergencyContact Json? // { name, relation, phone }
  bankDetails      Json? // { bankName, accountNo, ifsc, branch }
  governmentId     Json? // { type: 'PAN'|'AADHAAR'|'PASSPORT', number }
  teamId           String?
  designationId    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user            User                @relation(fields: [userId], references: [id])
  department      Department?         @relation(fields: [departmentId], references: [id])
  team            Team?               @relation(fields: [teamId], references: [id])
  designation     Designation?        @relation(fields: [designationId], references: [id])
  attendances     Attendance[]
  telemetry       EmployeeTelemetry[]
  screenshots     ScreenshotLog[]
  leaveRequests   LeaveRequest[]
  leaveBalances   LeaveBalance[]
  documents       EmployeeDocument[]
  payslips        Payslip[]
  timeEntries     TimeEntry[]
  onboardingTasks OnboardingTask[]
  interviews      InterviewSchedule[]
  reviews         Review[]            @relation("EmployeeReviews")
  givenReviews    Review[]            @relation("ReviewerReviews")
  goals           Goal[]

  @@map("employees")
}

model Attendance {
  id               String    @id @default(cuid())
  employeeId       String
  date             DateTime  @db.Date
  clockIn          DateTime?
  clockInPhotoUrl  String?
  clockOut         DateTime?
  clockOutPhotoUrl String?
  breakStart       DateTime?
  breakEnd         DateTime?
  status           String // PRESENT | ABSENT | LATE | HALF_DAY | HOLIDAY | LEAVE
  notes            String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendance")
}

model EmployeeTelemetry {
  id              String   @id @default(cuid())
  employeeId      String
  date            DateTime @db.Date
  timestamp       DateTime @default(now())
  activeMinutes   Int      @default(0)
  idleMinutes     Int      @default(0)
  keyboardStrokes Int      @default(0)
  mouseClicks     Int      @default(0)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@map("employee_telemetry")
}

model ScreenshotLog {
  id         String   @id @default(cuid())
  employeeId String
  timestamp  DateTime @default(now())
  imageUrl   String
  notes      String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, timestamp])
  @@map("screenshot_logs")
}

model TimeEntry {
  id          String    @id @default(cuid())
  employeeId  String
  date        DateTime  @db.Date
  startTime   DateTime
  endTime     DateTime?
  breakMins   Int       @default(0)
  description String?
  isOvertime  Boolean   @default(false)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  COMP_OFF
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  type       LeaveType
  startDate  DateTime    @db.Date
  endDate    DateTime    @db.Date
  days       Float
  reason     String
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime    @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model LeaveBalance {
  id         String    @id @default(cuid())
  employeeId String
  type       LeaveType
  balance    Float
  year       Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, type, year])
  @@map("leave_balances")
}

model Payslip {
  id              String    @id @default(cuid())
  employeeId      String
  month           Int
  year            Int
  basicSalary     Float
  hra             Float     @default(0)
  allowances      Float     @default(0)
  grossSalary     Float
  pfDeduction     Float     @default(0)
  esiDeduction    Float     @default(0)
  tdsDeduction    Float     @default(0)
  otherDeductions Float     @default(0)
  netSalary       Float
  paidAt          DateTime?
  createdAt       DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@map("payslips")
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  fileUrl    String
  type       String // ID | CONTRACT | TAX | OTHER
  uploadedBy String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_documents")
}

model PayrollConfig {
  id         String   @id @default(cuid())
  basicPct   Float    @default(50)
  hraPct     Float    @default(20)
  specialPct Float    @default(30)
  pfPct      Float    @default(12)
  pfMaxLimit Float    @default(1800)
  ptAmount   Float    @default(200)
  tdsLimit   Float    @default(60000)
  tdsPct     Float    @default(10)
  updatedAt  DateTime @updatedAt

  @@map("payroll_configs")
}

model OnboardingTask {
  id          String    @id @default(cuid())
  employeeId  String
  title       String
  description String?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("onboarding_tasks")
}

model JobPosting {
  id                  String   @id @default(cuid())
  title               String
  departmentId        String?
  description         String
  requirements        String[]
  status              String   @default("OPEN") // OPEN | CLOSED | DRAFT
  isPublicForStudents Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  candidates Candidate[]

  @@map("job_postings")
}

model Candidate {
  id           String   @id @default(cuid())
  jobPostingId String
  firstName    String
  lastName     String
  email        String
  phone        String?
  resumeUrl    String?
  status       String   @default("APPLIED") // APPLIED | SCREENING | INTERVIEW | OFFERED | REJECTED | HIRED
  appliedAt    DateTime @default(now())

  jobPosting JobPosting          @relation(fields: [jobPostingId], references: [id])
  interviews InterviewSchedule[]

  @@map("candidates")
}

model InterviewSchedule {
  id            String   @id @default(cuid())
  candidateId   String
  interviewerId String
  scheduledAt   DateTime
  durationMins  Int      @default(60)
  meetLink      String?
  feedback      String?
  status        String   @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED

  candidate   Candidate @relation(fields: [candidateId], references: [id])
  interviewer Employee  @relation(fields: [interviewerId], references: [id])

  @@map("interview_schedules")
}

model PerformanceCycle {
  id        String   @id @default(cuid())
  name      String // e.g. "Q1 2025 Review"
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  status    String   @default("ACTIVE") // ACTIVE | CLOSED

  reviews Review[]
  goals   Goal[]

  @@map("performance_cycles")
}

model Review {
  id         String   @id @default(cuid())
  cycleId    String
  employeeId String
  reviewerId String
  score      Float?
  feedback   String?
  status     String   @default("PENDING") // PENDING | COMPLETED
  createdAt  DateTime @default(now())

  cycle    PerformanceCycle @relation(fields: [cycleId], references: [id])
  employee Employee         @relation("EmployeeReviews", fields: [employeeId], references: [id])
  reviewer Employee         @relation("ReviewerReviews", fields: [reviewerId], references: [id])

  @@map("reviews")
}

// ─────────────────────────────────────────
// MODULE 04 — Finance & Accounting
// ─────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum EstimateStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

model Estimate {
  id              String         @id @default(cuid())
  estimateNumber  String         @unique
  projectId       String?
  clientName      String
  clientEmail     String?
  status          EstimateStatus @default(DRAFT)
  businessUnit    BusinessUnit
  subtotal        Float
  cgst            Float          @default(0)
  sgst            Float          @default(0)
  igst            Float          @default(0)
  totalAmount     Float
  currency        String         @default("INR")
  validUntil      DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items    EstimateItem[]
  project  Project?      @relation(fields: [projectId], references: [id])

  @@map("estimates")
}

model EstimateItem {
  id          String   @id @default(cuid())
  estimateId  String
  description String
  quantity    Float
  unitPrice   Float
  total       Float
  
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_items")
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  projectId       String?
  clientName      String
  clientEmail     String?
  clientGst       String?
  status          InvoiceStatus @default(DRAFT)
  businessUnit    BusinessUnit
  subtotal        Float
  discountRate    Float         @default(0)
  cgst            Float         @default(0)
  sgst            Float         @default(0)
  igst            Float         @default(0)
  totalAmount     Float
  paidAmount      Float         @default(0)
  currency        String        @default("INR")
  dueDate         DateTime
  isRecurring     Boolean       @default(false)
  recurringPeriod String?
  notes           String?
  razorpayLinkId  String?
  sentAt          DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items    InvoiceItem[]
  payments Payment[]
  billingMilestone BillingMilestone?

  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  discountRate Float  @default(0)
  taxRate     Float   @default(18)
  hsnCode     String?
  total       Float
  sortOrder   Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id            String   @id @default(cuid())
  invoiceId     String
  amount        Float
  method        String // RAZORPAY | BANK_TRANSFER | CASH | CHEQUE
  transactionId String?
  paidAt        DateTime @default(now())
  notes         String?

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model Expense {
  id          String    @id @default(cuid())
  employeeId  String?
  category    String // TRAVEL | SOFTWARE | OFFICE | PROJECT | OTHER
  amount      Float
  description String
  receiptUrl  String?
  projectId   String?
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED | PAID
  submittedAt DateTime  @default(now())
  approvedBy  String?
  approvedAt  DateTime?
  paidAt      DateTime?

  @@map("expenses")
}

model Budget {
  id           String       @id @default(cuid())
  name         String
  departmentId String?
  projectId    String?
  businessUnit BusinessUnit
  amount       Float
  period       String // Q1-2025 | 2025-06 | FY2025
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime     @default(now())

  @@map("budgets")
}

// ─────────────────────────────────────────
// MODULE 05 — Student Management
// ─────────────────────────────────────────

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  ADMITTED
  DEFERRED
  REJECTED
}

enum DeliveryMode {
  ONLINE
  ONSITE
  HYBRID
}

model Student {
  id           String    @id @default(cuid())
  userId       String    @unique
  studentCode  String    @unique
  deliveryMode DeliveryMode @default(ONSITE)
  dateOfBirth  DateTime? @db.Date
  address      String?
  parentName       String?
  parentPhone      String?
  gender           String?
  profession       String?
  college          String?
  bloodGroup       String?   // A+, A-, B+, B-, O+, O-, AB+, AB-
  emergencyContact String?   // JSON: { name, phone, relation }
  interestAreas    String[]
  learningLanguage String?
  country          String?
  state            String?
  city             String?
  currentStreak    Int       @default(0)
  portfolio    String?
  isAlumni     Boolean   @default(false)
  graduatedAt  DateTime?
  xp           Int       @default(0)
  careerScore  Int       @default(0)  // 0-100, computed
  referralCode String?   @unique
  referredById String?
  leadId       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  user        User           @relation(fields: [userId], references: [id])
  application Application?
  enrollments Enrollment[]
  Certificate Certificate[]
  QuizAttempt QuizAttempt[]
  badges          StudentBadge[]
  portfolioProfile StudentPortfolio?
  skills          SkillMatrix[]
  projectMembers  AcademyProjectMember[]
  internships     Internship[]
  placements      PlacementApplication[]
  wallet          DigitalWallet?
  purchases       MarketplacePurchase[]
  eventRegs       EventRegistration[]
  payoutsEarned   ReferralPayout[]   @relation("ReferrerPayouts")
  payoutAsReferee ReferralPayout[]   @relation("ReferredPayouts")

  referredBy        Student?   @relation("StudentReferrals", fields: [referredById], references: [id])
  referrals         Student[]  @relation("StudentReferrals")
  commissionsEarned Referral[] @relation("ReferrerCommissions")
  referralRecord    Referral?  @relation("ReferredStudent")
  officeHourBookings OfficeHourBooking[]
  attendanceRecords  StudentAttendance[]

  @@map("students")
}

model StudentAttendance {
  id          String   @id @default(cuid())
  studentId   String
  date        DateTime @db.Date
  status      String   @default("PRESENT") // PRESENT, LATE, ABSENT
  scannedAt   DateTime @default(now())
  location    String?
  notes       String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@map("student_attendance")
}

model SkillMatrix {
  id         String   @id @default(cuid())
  studentId  String
  skillName  String   // e.g. "Graphic Design", "Figma", "Communication"
  category   String   // TECHNICAL | SOFT | TOOL | DOMAIN
  rating     Int      @default(0) // 0–5 stars
  endorsedBy String?  // Educator userId who verified this
  notes      String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, skillName])
  @@map("skill_matrix")
}

model Application {
  id           String            @id @default(cuid())
  studentId    String            @unique
  courseId     String?
  status       ApplicationStatus @default(SUBMITTED)
  portfolioUrl String?
  statement    String?
  reviewNotes  String?
  reviewedBy   String?
  appliedAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@map("applications")
}

model Course {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  duration    String // e.g., "3 months", "6 months"
  fee         Float
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  batches     Batch[]
  lmsCourse   LMSCourse?
  Certificate Certificate[]
  Quiz        Quiz[]

  @@map("courses")
}

model Batch {
  id        String   @id @default(cuid())
  courseId  String
  educatorId String?
  name      String // e.g., "GD-Batch-24-Morning"
  type      String // MORNING | EVENING | WEEKEND | ONLINE
  capacity  Int      @default(20)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  course      Course         @relation(fields: [courseId], references: [id])
  educator    Educator?      @relation(fields: [educatorId], references: [id])
  enrollments Enrollment[]
  sessions    BatchSession[]

  @@map("batches")
}

model BatchSession {
  id           String   @id @default(cuid())
  batchId      String
  educatorId   String?
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime
  location     String?
  meetLink     String?
  recordingUrl String?
  createdAt    DateTime @default(now())

  batch       Batch               @relation(fields: [batchId], references: [id])
  attendances SessionAttendance[]

  @@map("batch_sessions")
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  batchId    String
  enrolledAt DateTime @default(now())
  feePaid    Float    @default(0)
  totalFee   Float
  status     String   @default("ACTIVE") // ACTIVE | COMPLETED | DROPPED

  student      Student          @relation(fields: [studentId], references: [id])
  batch        Batch            @relation(fields: [batchId], references: [id])
  installments FeeInstallment[]

  @@unique([studentId, batchId])
  @@map("enrollments")
}

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

model FeeInstallment {
  id           String    @id @default(cuid())
  enrollmentId String
  dueDate      DateTime  @db.Date
  amount       Float
  taxAmount    Float     @default(0)
  paidAmount   Float     @default(0)
  status       FeeStatus @default(PENDING)
  paidAt       DateTime?
  paymentRef   String?   // UPI txn ID, cheque number, etc.
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  enrollment Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  followUps  FeeFollowUp[]

  @@map("fee_installments")
}

model FeeFollowUp {
  id             String    @id @default(cuid())
  installmentId  String
  staffId        String?
  channel        String    // CALL | WHATSAPP | EMAIL | VISIT
  notes          String?
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())

  installment FeeInstallment @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  @@map("fee_follow_ups")
}

// ─────────────────────────────────────────────────────────────
// ACADEMY — LIVE PROJECT HUB
// ─────────────────────────────────────────────────────────────

enum AcademyProjectType {
  INTERNAL
  CLIENT
  INDUSTRY
  HACKATHON
  RESEARCH
  COMPETITION
  FREELANCE
}

enum AcademyProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

model AcademyProject {
  id          String               @id @default(cuid())
  title       String
  type        AcademyProjectType
  status      AcademyProjectStatus @default(PLANNING)
  batchId     String?
  mentorId    String?              // Educator userId
  description String?
  githubUrl   String?
  figmaUrl    String?
  driveUrl    String?
  presentationUrl String?
  clientName  String?
  clientFeedback String?
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  members     AcademyProjectMember[]
  tasks       AcademyProjectTask[]

  @@map("academy_projects")
}

model AcademyProjectMember {
  id        String   @id @default(cuid())
  projectId String
  studentId String
  role      String   @default("MEMBER") // LEAD | MEMBER
  joinedAt  DateTime @default(now())

  project AcademyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([projectId, studentId])
  @@map("academy_project_members")
}

model AcademyProjectTask {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  assignedTo  String?  // studentId
  status      String   @default("TODO") // TODO | IN_PROGRESS | DONE
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  project AcademyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("academy_project_tasks")
}

// ─────────────────────────────────────────────────────────────
// ACADEMY — INTERNSHIP PORTAL
// ─────────────────────────────────────────────────────────────

enum InternshipStatus {
  APPLIED
  SELECTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model Internship {
  id           String          @id @default(cuid())
  studentId    String
  companyName  String
  role         String
  stipend      Float?
  startDate    DateTime?
  endDate      DateTime?
  mentorName   String?
  mentorEmail  String?
  status       InternshipStatus @default(APPLIED)
  offerLetterUrl String?
  certificateUrl String?
  performanceScore Int?        // 0-100
  mentorFeedback String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  student  Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dailyLogs InternshipLog[]

  @@map("internships")
}

model InternshipLog {
  id           String   @id @default(cuid())
  internshipId String
  date         DateTime @db.Date
  summary      String
  hoursWorked  Float    @default(8)
  createdAt    DateTime @default(now())

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@map("internship_logs")
}

// ─────────────────────────────────────────────────────────────
// ACADEMY — PLACEMENT ENGINE
// ─────────────────────────────────────────────────────────────

enum PlacementStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEW_DONE
  OFFER_RECEIVED
  OFFER_ACCEPTED
  JOINED
  REJECTED
}

model PlacementCompany {
  id          String   @id @default(cuid())
  name        String
  website     String?
  industry    String?
  logoUrl     String?
  contactName String?
  contactEmail String?
  contactPhone String?
  createdAt   DateTime @default(now())

  jobs PlacementJob[]

  @@map("placement_companies")
}

model PlacementJob {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  description String?
  location    String?
  salaryMin   Float?
  salaryMax   Float?
  skills      String[] // Required skills
  minCareerScore Int   @default(0)  // Minimum career score to be eligible
  openDate    DateTime @default(now())
  closeDate   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  company      PlacementCompany     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications PlacementApplication[]

  @@map("placement_jobs")
}

model PlacementApplication {
  id           String          @id @default(cuid())
  jobId        String
  studentId    String
  status       PlacementStatus @default(APPLIED)
  appliedAt    DateTime        @default(now())
  interviewAt  DateTime?
  offerAmount  Float?
  offerDate    DateTime?
  joinedDate   DateTime?
  rejectionReason String?
  notes        String?
  updatedAt    DateTime        @updatedAt

  job     PlacementJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([jobId, studentId])
  @@map("placement_applications")
}

model SessionAttendance {
  id        String  @id @default(cuid())
  sessionId String
  studentId String
  status    String  @default("PRESENT") // PRESENT | ABSENT | LATE
  markedBy  String?

  session BatchSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, studentId])
  @@map("session_attendance")
}

// ─────────────────────────────────────────
// MODULE 06 — LMS
// ─────────────────────────────────────────

model LMSCourse {
  id            String    @id @default(cuid())
  courseId      String    @unique
  thumbnail     String?
  outcomes      String[]
  prerequisites String[]
  isPublished   Boolean   @default(false)
  pricing       Float?
  seoTitle      String?
  trailerVideoId String?
  draftStatus   String    @default("DRAFT") // DRAFT | PENDING_REVIEW | PUBLISHED
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  course  Course      @relation(fields: [courseId], references: [id])
  modules LMSModule[]

  @@map("lms_courses")
}

model LMSModule {
  id          String   @id @default(cuid())
  lmsCourseId String
  title       String
  sortOrder   Int
  createdAt   DateTime @default(now())

  lmsCourse LMSCourse   @relation(fields: [lmsCourseId], references: [id], onDelete: Cascade)
  lessons   LMSLesson[]
  Quiz      Quiz[]

  @@map("lms_modules")
}

enum LessonType {
  VIDEO
  PDF
  SLIDE
  LIVE_SESSION
  ASSIGNMENT
  QUIZ
  LINK
  TEXT
  CODE
  DESIGN
  RICH_TEXT
}

model LMSLesson {
  id          String     @id @default(cuid())
  moduleId    String
  title       String
  type        LessonType
  contentUrl  String? // Video URL, PDF URL, slide embed
  videoId     String? // Cloudflare Stream / Mux ID
  duration    Int? // Minutes
  description String?
  richText    String? // Notion-style block JSON or HTML
  isPreview   Boolean    @default(false)
  sortOrder   Int
  resources   Json? // Downloadable resources array
  createdAt   DateTime   @default(now())

  module   LMSModule        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@map("lms_lessons")
}

model LessonProgress {
  id           String    @id @default(cuid())
  lessonId     String
  studentId    String
  isCompleted  Boolean   @default(false)
  watchedSecs  Int       @default(0)
  completedAt  DateTime?
  lastPosition Int       @default(0) // Video resume position in seconds
  updatedAt    DateTime  @updatedAt

  lesson LMSLesson @relation(fields: [lessonId], references: [id])

  @@unique([lessonId, studentId])
  @@map("lesson_progress")
}

model Assignment {
  id           String    @id @default(cuid())
  lessonId     String?
  batchId      String?
  title        String
  brief        String
  rubric       Json? // Grading rubric JSON
  dueDate      DateTime?
  maxScore     Int       @default(100)
  isPeerReview Boolean   @default(false)
  createdAt    DateTime  @default(now())

  submissions AssignmentSubmission[]

  @@map("assignments")
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  GRADED
  RESUBMIT_REQUESTED
  APPROVED        // Final approved — triggers auto portfolio push
  FINAL
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrls     String[]
  linkUrl      String?
  status       SubmissionStatus @default(DRAFT)
  grade        Int?
  feedback     String?
  gradedBy     String?
  gradedAt     DateTime?
  versionCount Int              @default(1)
  pushedToPortfolio Boolean    @default(false)
  submittedAt  DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignment  Assignment              @relation(fields: [assignmentId], references: [id])
  versions    SubmissionVersion[]
  annotations MentorAnnotation[]

  @@map("assignment_submissions")
}

model SubmissionVersion {
  id           String   @id @default(cuid())
  submissionId String
  version      Int      // 1, 2, 3...
  fileUrls     String[]
  linkUrl      String?
  note         String?  // Student's note about what changed
  submittedAt  DateTime @default(now())

  submission AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_versions")
}

model MentorAnnotation {
  id           String   @id @default(cuid())
  submissionId String
  mentorId     String
  content      String   // The annotation / feedback text
  position     String?  // Optional: { x, y, page } for PDF overlay
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  submission AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("mentor_annotations")
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  imageUrl    String?
  criteria    String // e.g., "COMPLETE_MODULE_1", "SCORE_100_ASSIGNMENT"
  xpReward    Int      @default(0)
  createdAt   DateTime @default(now())

  studentBadges StudentBadge[]

  @@map("badges")
}

model StudentBadge {
  id        String   @id @default(cuid())
  studentId String
  badgeId   String
  earnedAt  DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badge   Badge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId])
  @@map("student_badges")
}

// ─────────────────────────────────────────
// MODULE 09 — Vendor Management
// ─────────────────────────────────────────

enum VendorType {
  CREATIVE
  TECHNICAL
  OPERATIONAL
  SUPPLIER
}

model Vendor {
  id          String     @id @default(cuid())
  userId      String     @unique
  vendorCode  String     @unique
  type        VendorType
  company     String?
  skills      String[]
  dayRate     Float?
  projectRate Float?
  rating      Float      @default(0)
  gstin       String?
  createdAt   DateTime   @default(now())

  user        User               @relation(fields: [userId], references: [id])
  assignments VendorAssignment[]

  @@map("vendors")
}

model VendorAssignment {
  id          String    @id @default(cuid())
  vendorId    String
  projectId   String
  brief       String?
  deadline    DateTime?
  status      String    @default("ASSIGNED") // ASSIGNED | SUBMITTED | APPROVED | PAID
  rating      Int?
  ratingNotes String?
  agreedRate  Float?
  createdAt   DateTime  @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_assignments")
}

// ─────────────────────────────────────────
// MODULE 12 — Notifications
// ─────────────────────────────────────────

enum NotificationType {
  TASK_ASSIGNED
  DEADLINE_APPROACHING
  APPROVAL_NEEDED
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  MILESTONE_REACHED
  LEAVE_APPROVED
  ASSIGNMENT_GRADED
  NEW_MESSAGE
  INFO
  SUCCESS
  WARNING
  ERROR
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Announcement {
  id          String     @id @default(cuid())
  title       String
  content     String
  targetRoles UserRole[]
  isPinned    Boolean    @default(false)
  publishedAt DateTime   @default(now())
  expiresAt   DateTime?
  createdBy   String

  @@map("announcements")
}

model GraftyMessageLog {
  id          String   @id @default(cuid())
  recipient   String // Phone number
  templateId  String
  payload     Json
  status      String // SENT | DELIVERED | FAILED | READ
  triggeredBy String // Module that triggered it
  triggerId   String // ID of the triggering record
  sentAt      DateTime @default(now())

  @@map("grafty_message_logs")
}

// ─────────────────────────────────────────
// MODULE 13 — Document Generation
// ─────────────────────────────────────────

enum DocumentType {
  CERTIFICATE
  EXPERIENCE_LETTER
  OFFER_LETTER
  CUSTOM
  PROPOSAL
  CONTRACT
}

model DocumentTemplate {
  id        String       @id @default(cuid())
  name      String
  type      DocumentType
  content   String // HTML or rich text template with variables like {{NAME}}
  variables String[] // e.g., ["NAME", "ROLE", "START_DATE", "END_DATE"]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  documents GeneratedDocument[]

  @@map("document_templates")
}

model GeneratedDocument {
  id          String   @id @default(cuid())
  templateId  String
  userId      String? // Target user (Employee or Student)
  proposalId  String? // Target proposal
  documentUrl String? // Optional: if we store the final PDF to S3/Cloud
  metadata    Json? // Snapshot of variables used
  generatedBy String // HR/Admin who generated it
  createdAt   DateTime @default(now())

  template DocumentTemplate @relation(fields: [templateId], references: [id])
  user     User?            @relation(fields: [userId], references: [id])
  proposal Proposal?        @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("generated_documents")
}

// ─────────────────────────────────────────
// MODULE 14 — Marketing Hub
// ─────────────────────────────────────────

model Campaign {
  id             String    @id @default(cuid())
  title          String
  type           String // EMAIL, AD, SOCIAL
  status         String // DRAFT, SCHEDULED, ACTIVE, COMPLETED
  budget         Float?
  content        String? // Email HTML body
  targetAudience String?
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("campaigns")
}

model SocialPost {
  id        String    @id @default(cuid())
  content   String
  platform  String // TWITTER, LINKEDIN, INSTAGRAM
  status    String // DRAFT, SCHEDULED, PUBLISHED
  publishAt DateTime?
  authorId  String
  createdAt DateTime  @default(now())

  @@map("social_posts")
}

// ─────────────────────────────────────────
// MODULE 15 — Support Helpdesk
// ─────────────────────────────────────────

model Ticket {
  id         String   @id @default(cuid())
  subject    String
  status     String // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority   String // LOW, MEDIUM, HIGH, URGENT
  userId     String // The user (student/client) who opened the ticket
  assignedTo String? // Staff member ID handling the ticket
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages TicketMessage[]

  @@map("tickets")
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String
  message    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@map("ticket_messages")
}

// ─────────────────────────────────────────
// MODULE 16 — Automations & Workflows
// ─────────────────────────────────────────

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  triggerType String // e.g. "ON_LEAD_CREATED", "ON_INVOICE_PAID"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps WorkflowStep[]
  logs  WorkflowLog[]

  @@map("workflows")
}

model WorkflowStep {
  id         String   @id @default(cuid())
  workflowId String
  stepOrder  Int
  actionType String // e.g. "SEND_EMAIL", "SEND_WHATSAPP", "CREATE_TASK"
  config     Json // e.g. { "templateId": "...", "recipient": "{{lead.email}}" }
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_steps")
}

model WorkflowLog {
  id          String   @id @default(cuid())
  workflowId  String
  triggerData Json
  status      String // SUCCESS, FAILED
  error       String?
  executedAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_logs")
}

// ─────────────────────────────────────────
// MODULE 17 — Real-Time Communication (Chat)
// ─────────────────────────────────────────

model ChatChannel {
  id        String   @id @default(cuid())
  name      String? // Null for direct messages
  type      String // DIRECT, GROUP, PROJECT
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("chat_channels")
}

model ChatParticipant {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation("UserChatParticipants", fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_participants")
}

model ChatMessage {
  id         String   @id @default(cuid())
  channelId  String
  senderId   String
  content    String
  attachment String? // URL if any
  createdAt  DateTime @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User        @relation("UserChatMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ─────────────────────────────────────────
// MODULE 18 — Central Asset Drive
// ─────────────────────────────────────────

model DriveFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String? // Null for root folders
  projectId String? // Optional tie to a project
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files DriveFile[]

  @@map("drive_folders")
}

model DriveFile {
  id         String   @id @default(cuid())
  folderId   String?
  name       String
  fileUrl    String
  mimeType   String
  sizeBytes  Int
  uploadedBy String
  createdAt  DateTime @default(now())

  folder DriveFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@map("drive_files")
}

// ─────────────────────────────────────────
// MODULE 19 — Settings & RBAC
// ─────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  permissions Permission[]
  User        User[]

  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  roleId   String
  resource String // e.g. "PROJECTS", "FINANCE"
  action   String // e.g. "READ", "WRITE", "DELETE", "ALL"

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("permissions")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String

  @@map("system_settings")
}

// ─────────────────────────────────────────
// MODULE 20 — CMS (Landing Pages)
// ─────────────────────────────────────────

model LandingPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  customHtml  String?  @db.Text
  customCss   String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections PageSection[]

  @@map("landing_pages")
}

model PageSection {
  id            String   @id @default(cuid())
  landingPageId String
  sectionId     String
  content       Json
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@unique([landingPageId, sectionId])
  @@map("page_sections")
}

// ─────────────────────────────────────────
// MODULE 21 — Certificates
// ─────────────────────────────────────────

model Certificate {
  id               String   @id @default(cuid())
  certificateId    String   @unique // e.g., "GRK-2026-XYZ"
  verificationCode String   @unique @default(cuid()) // Short code for public verify page
  studentId        String
  courseId         String
  issuedAt         DateTime @default(now())
  grade            String?
  pdfUrl           String?  // S3/hosted PDF URL
  whatsappSent     Boolean  @default(false)
  emailSent        Boolean  @default(false)
  metadata         Json?    // Optional extra info (e.g. skills acquired)

  student Student @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("certificates")
}

// ─────────────────────────────────────────
// MODULE 22 — Community Forums
// ─────────────────────────────────────────

model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String? // e.g. "bg-blue-500"
  courseId    String? // If null, it's a global category
  createdAt   DateTime @default(now())

  posts ForumPost[]

  @@map("forum_categories")
}

model ForumPost {
  id         String   @id @default(cuid())
  categoryId String
  authorId   String // User ID
  title      String
  content    String
  isPinned   Boolean  @default(false)
  upvotes    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ForumCategory @relation(fields: [categoryId], references: [id])
  author   User          @relation(fields: [authorId], references: [id])
  replies  ForumReply[]

  @@map("forum_posts")
}

model ForumReply {
  id         String   @id @default(cuid())
  postId     String
  authorId   String // User ID
  content    String
  isAccepted Boolean  @default(false)
  upvotes    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User      @relation(fields: [authorId], references: [id])

  @@map("forum_replies")
}

// ─────────────────────────────────────────
// MODULE 23 — Quizzes & Assessments
// ─────────────────────────────────────────

model Quiz {
  id           String   @id @default(cuid())
  courseId     String
  moduleId     String? // Optional, if linked to a specific LMSModule
  title        String
  description  String?
  passingScore Int      @default(80) // Out of 100
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  course Course     @relation(fields: [courseId], references: [id])
  module LMSModule? @relation(fields: [moduleId], references: [id])

  @@map("quizzes")
}

model QuizQuestion {
  id            String  @id @default(cuid())
  quizId        String
  questionText  String
  options       Json // e.g. ["A", "B", "C", "D"]
  correctOption Int // Index of correct option (0-3)
  explanation   String?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  studentId String
  score     Int
  passed    Boolean
  createdAt DateTime @default(now())

  quiz    Quiz    @relation(fields: [quizId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("quiz_attempts")
}

// ─────────────────────────────────────────
// MODULE 24 — Referrals & Affiliates
// ─────────────────────────────────────────

model Referral {
  id             String   @id @default(cuid())
  referrerId     String // The student who shared the link
  referredUserId String   @unique // The new student who signed up
  status         String   @default("PENDING") // PENDING | CONVERTED | PAID
  commissionAmt  Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referrer     Student @relation("ReferrerCommissions", fields: [referrerId], references: [id])
  referredUser Student @relation("ReferredStudent", fields: [referredUserId], references: [id])

  @@map("referrals")
}

// ─────────────────────────────────────────
// MODULE 25 — Office Hours (Google Meet)
// ─────────────────────────────────────────

model OfficeHour {
  id           String   @id @default(cuid())
  title        String
  mentorId     String
  meetLink     String?
  scheduledFor DateTime
  durationMins Int      @default(15)
  capacity     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mentor   User                @relation(fields: [mentorId], references: [id])
  bookings OfficeHourBooking[]

  @@map("office_hours")
}

model OfficeHourBooking {
  id           String   @id @default(cuid())
  officeHourId String
  studentId    String
  notes        String?
  status       String   @default("CONFIRMED") // CONFIRMED, CANCELLED
  createdAt    DateTime @default(now())

  officeHour OfficeHour @relation(fields: [officeHourId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([officeHourId, studentId])
  @@map("office_hour_bookings")
}


// ─────────────────────────────────────────
// MODULE 06+ — LMS 2.0 Extended EduOS
// ─────────────────────────────────────────

model Educator {
  id                 String    @id @default(cuid())
  userId             String    @unique
  designation        String?
  company            String?
  yearsExperience    Int?
  skills             String[]
  bio                String?
  portfolioUrl       String?
  linkedInUrl        String?
  verificationStatus String    @default("PENDING") // PENDING | VERIFIED | REJECTED
  deliveryMode       DeliveryMode @default(ONSITE)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  batches Batch[]
  
  @@map("educators")
}

enum QuestionType {
  MCQ
  MULTI_SELECT
  TRUE_FALSE
  ESSAY
  CODE
  MATCHING
}

model StudentPortfolio {
  id          String   @id @default(cuid())
  studentId   String   @unique
  bio         String?
  resumeUrl   String?
  githubUrl   String?
  behanceUrl  String?
  dribbbleUrl String?
  isPublic    Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projects PortfolioProject[]

  @@map("student_portfolios")
}

model PortfolioProject {
  id          String   @id @default(cuid())
  portfolioId String
  title       String
  description String
  imageUrl    String?
  mediaUrls   String[] // assignment files, screenshots, etc.
  linkUrl     String?
  category    String   @default("PROJECT") // PROJECT | ASSIGNMENT | CERTIFICATE | INTERNSHIP
  createdAt   DateTime @default(now())

  portfolio StudentPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("portfolio_projects")
}

model DiscussionForum {
  id          String   @id @default(cuid())
  courseId    String?  // If tied to a course
  title       String
  description String?
  createdAt   DateTime @default(now())

  threads DiscussionThread[]

  @@map("discussion_forums")
}

model DiscussionThread {
  id        String   @id @default(cuid())
  forumId   String
  authorId  String   // User ID
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())

  forum   DiscussionForum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  replies DiscussionReply[]

  @@map("discussion_threads")
}

model DiscussionReply {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String   // User ID
  content   String
  createdAt DateTime @default(now())

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("discussion_replies")
}

// ─────────────────────────────────────────────────────────────
// MODULE 26 — WALLET & REWARDS
// ─────────────────────────────────────────────────────────────

model DigitalWallet {
  id        String   @id @default(cuid())
  studentId String   @unique
  balance   Float    @default(0)
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student      Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("digital_wallets")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  amount      Float
  type        String   // CREDIT | DEBIT
  source      String   // REFERRAL | SCHOLARSHIP | REFUND | PURCHASE | REWARD
  description String?
  createdAt   DateTime @default(now())

  wallet DigitalWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

// ─────────────────────────────────────────────────────────────
// MODULE 27 — MARKETPLACE
// ─────────────────────────────────────────────────────────────

model MarketplaceItem {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  type        String   // COURSE | TEMPLATE | TICKET | SESSION | BOOK
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  purchases MarketplacePurchase[]

  @@map("marketplace_items")
}

model MarketplacePurchase {
  id         String   @id @default(cuid())
  studentId  String
  itemId     String
  amountPaid Float
  createdAt  DateTime @default(now())

  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  item    MarketplaceItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("marketplace_purchases")
}

// ─────────────────────────────────────────────────────────────
// MODULE 28 — EVENT MANAGEMENT
// ─────────────────────────────────────────────────────────────

model CampusEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   // WORKSHOP | HACKATHON | GUEST_SESSION | WEBINAR
  date        DateTime
  location    String?
  maxCapacity Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  registrations EventRegistration[]

