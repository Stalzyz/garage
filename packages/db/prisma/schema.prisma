  authorId    String   // Student or Educator userId
  content     String
  mediaUrls   String[]
  likesCount  Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("community_posts")
}

// ─────────────────────────────────────────────────────────────
// MODULE 30 — REFERRAL SYSTEM
// ─────────────────────────────────────────────────────────────

model ReferralPayout {
  id            String   @id @default(cuid())
  referrerId    String
  referredId    String
  amount        Float
  courseType    String   // ONSITE | ONLINE
  percentage    Float
  status        String   @default("PENDING") // PENDING | PAID | REJECTED
  paidAt        DateTime?
  paymentMethod String?  // UPI, BANK_TRANSFER, CASH
  transactionId String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  referrer      Student  @relation("ReferrerPayouts", fields: [referrerId], references: [id], onDelete: Cascade)
  referred      Student  @relation("ReferredPayouts", fields: [referredId], references: [id], onDelete: Cascade)

  @@map("referral_payouts")
}

// ─────────────────────────────────────────────────────────────
// MODULE 31 — WALK-IN & DEMO REGISTRATION
// ─────────────────────────────────────────────────────────────

enum WalkInStatus {
  NEW
  COUNSELLING
  DEMO_SCHEDULED
  CONVERTED
  FOLLOW_UP
  COLD
  LOST
}

enum WalkInType {
  WALKIN
  DEMO
  ENQUIRY
  CAMPUS_TOUR
}

model WalkIn {
  id              String       @id @default(cuid())
  name            String
  phone           String
  email           String?
  interestArea    String       // Course or program name
  type            WalkInType   @default(WALKIN)
  source          String       @default("OTHER") // GOOGLE | INSTAGRAM | FACEBOOK | FRIEND | REFERRAL | YOUTUBE | HOARDING | OTHER
  status          WalkInStatus @default(NEW)
  counsellorId    String?      // Assigned counsellor User ID
  preferredDate   DateTime?    // Preferred demo date
  notes           String?
  followUpAt      DateTime?
  convertedAt     DateTime?
  whatsappSent    Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  demoRegistration DemoRegistration?

  @@map("walk_ins")
}

model DemoSession {
  id          String   @id @default(cuid())
  title       String
  courseId    String?
  scheduledAt DateTime
  durationMins Int     @default(60)
  venue       String?
  meetLink    String?
  capacity    Int      @default(20)
  mentorId    String?  // Presenter / mentor User ID
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  registrations DemoRegistration[]

  @@map("demo_sessions")
}

model DemoRegistration {
  id            String   @id @default(cuid())
  demoSessionId String
  walkInId      String   @unique
  status        String   @default("REGISTERED") // REGISTERED | ATTENDED | NO_SHOW | INTERESTED | NOT_INTERESTED
  feedback      String?
  createdAt     DateTime @default(now())

  demoSession DemoSession @relation(fields: [demoSessionId], references: [id], onDelete: Cascade)
  walkIn      WalkIn      @relation(fields: [walkInId], references: [id], onDelete: Cascade)

  @@map("demo_registrations")
}

// ─────────────────────────────────────────────────────────────
// MODULE 32 — DYNAMIC FORM BUILDER
// ─────────────────────────────────────────────────────────────

model EnquiryForm {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  fields      Json     // Array of { id, label, type, required, options }
  createLead  Boolean  @default(true) // Whether to push to Admission CRM
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions FormSubmission[]

  @@map("enquiry_forms")
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  data      Json     // Collected responses { fieldId: value }
  leadId    String?  // Reference to created lead if applicable
  createdAt DateTime @default(now())

  form EnquiryForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_submissions")
}

model Goal {
  id          String    @id @default(cuid())
  employeeId  String
  title       String
  description String?
  targetDate  DateTime? @db.Date
  progress    Int       @default(0)
  status      String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, ACHIEVED, MISSED
  cycleId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle    PerformanceCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@map("goals")
}
